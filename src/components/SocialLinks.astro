<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .social-links {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .social-links li {
    display: flex;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 100%;
    box-shadow: inset 0 0 0 2px var(--color-border);
    transition: box-shadow 0.2s ease, color 0.2s ease;
    color: var(--color-heading);
    border-bottom: none;
  }

  .social-links a:hover {
    box-shadow: inset 0 0 0 2px var(--color-accent);
    color: var(--color-accent);
  }

  .social-links svg {
    width: 1.25rem;
    height: 1.25rem;
    fill: currentColor;
  }
</style>
